{
  "buildCommand": "pnpm install --filter @workspace/store-control... && pnpm --filter @workspace/store-control run build:standalone",
  "outputDirectory": "artifacts/store-control/dist/public",
  "installCommand": "echo skip",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
